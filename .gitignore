/dist-newstyle/
*.csv
*.html
*.txt
*.png
*.svg

# Track demo data CSVs under data/ (reproducible inputs)
!data/**/*.csv

# Ignore the trash directory entirely (output artifacts; user-managed cleanup)
/trash/

# データ生成器は git 管理外 (確認用、CSV だけ commit する)
/demo/io/PotentialGen.hs

bench/venv/
/report.log

# Profiling artifacts (generated by `cabal run --enable-profiling`)
*.prof
*.hp
*.aux
*.ps

# Local-only cabal profiling/optimization config
/cabal.project.local
!bench/requirements.txt
!bench/**/*.csv
!bench/**/*.txt
!bench/**/*.html
!bench/**/*.png
!bench/**/*.svg

# bench/data/ の合成 CSV は `cabal run bench-data-gen` で決定的に
# 再生成可能 (固定 seed)。GitHub の 100 MB 制限を超える大規模ケース
# (lm_n100000_p100.csv = 132 MB 等) を含むため、git 管理外にする。
bench/data/

# 編集時の一時ファイル
*.tmp

# HPotfire からの申し送り類は git 管理外 (PR ごとに done/ 移動 or 削除する運用)
/request/
/HANALYZE_REQUESTS.md
_trash/
